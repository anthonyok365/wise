# Application settings
APP_NAME="Hiring Signal Detector"
DEBUG=false
LOG_LEVEL=INFO

# Database settings
DB_HOST=localhost
DB_PORT=5432
DB_USER=hiring_signal
DB_PASSWORD=hiring_signal_pass
DB_NAME=hiring_signal_db

# Redis settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# AI settings
AI_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral
# HuggingFace settings (optional)
HUGGINGFACE_TOKEN=
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# Scraper settings
SCRAPER_TIMEOUT=30000
SCRAPER_NAVIGATION_TIMEOUT=60000
SCRAPER_DELAY_BETWEEN_REQUESTS=2.0
SCRAPER_MAX_RETRIES=3
SCRAPER_USER_AGENT_ROTATION=true
SCRAPER_HEADLESS=true

# Scheduler settings
SCHEDULER_ENABLED=true
SCHEDULER_SCRAPER_INTERVAL_HOURS=6
SCHEDULER_VALIDATOR_INTERVAL_HOURS=24
SCHEDULER_SCORING_INTERVAL_HOURS=1
